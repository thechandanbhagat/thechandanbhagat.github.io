    "faq": [
      {
        "question": "How does Group Code work?",
        "answer": "Group Code scans your codebase for special @group comments and organizes code sections by their group names, allowing you to navigate by functionality rather than file structure."
      },
      {
        "question": "Which languages are supported?",
        "answer": "Group Code supports JavaScript, TypeScript, Python, Java, C#, Go, and more. The extension automatically detects comment syntax for each language."
      },
      {
        "question": "Can I use custom group names?",
        "answer": "Yes! You can use any name after @group. For example: @group user-authentication, @group data-processing, etc."
      }
    ]
  },
