  "groupcode": {
    "title": "Group Code",
    "subtitle": "VS Code Extension for Better Code Organization",
    "description": "Navigate Code by Functionality, Not Just Files. Group Code transforms how you organize and navigate your codebase using special comments to tag related code sections across multiple files and languages.",
    "logo": "/groupcode/compass-icon.svg",
    "installUrl": "https://marketplace.visualstudio.com/items?itemName=thechandanbhagat.groupcode",
    "githubUrl": "https://github.com/thechandanbhagat/groupcode",
    "features": [
      {
        "title": "Multi-Language Support",
        "description": "Works across different programming languages with intelligent comment detection",
        "icon": "fas fa-globe"
      },
      {
        "title": "Smart Navigation",
        "description": "Quickly jump between related code sections regardless of file location",
        "icon": "fas fa-compass"
      },
      {
        "title": "Visual Organization",
        "description": "See your code organized by functionality rather than just file structure",
        "icon": "fas fa-sitemap"
      },
      {
        "title": "Team Collaboration",
        "description": "Share code organization patterns with your team members",
        "icon": "fas fa-users"
      }
    ],
    "supportedLanguages": [
      {
        "name": "JavaScript",
        "extensions": ["js", "jsx"],
        "comment": "// @group",
        "icon": "fab fa-js-square"
      },
      {
        "name": "TypeScript",
        "extensions": ["ts", "tsx"],
        "comment": "// @group",
        "icon": "fab fa-js-square"
      },
      {
        "name": "Python",
        "extensions": ["py"],
        "comment": "# @group",
        "icon": "fab fa-python"
      },
      {
        "name": "Java",
        "extensions": ["java"],
        "comment": "// @group",
        "icon": "fab fa-java"
      },
      {
        "name": "C#",
        "extensions": ["cs"],
        "comment": "// @group",
        "icon": "fas fa-code"
      },
      {
        "name": "Go",
        "extensions": ["go"],
        "comment": "// @group",
        "icon": "fab fa-golang"
      }
    ],
    "installation": {
      "steps": [
        {
          "title": "Install from VS Code Marketplace",
          "description": "Search for 'Group Code' in the Extensions panel or install directly from the marketplace",
          "icon": "fas fa-download"
        },
        {
          "title": "Reload VS Code",
          "description": "Restart VS Code to activate the extension",
          "icon": "fas fa-sync-alt"
        },
        {
          "title": "Start Organizing",
          "description": "Begin adding @group comments to your code",
          "icon": "fas fa-play"
        }
      ]
    },
    "usage": {
      "examples": [
        {
          "language": "JavaScript",
          "code": "// @group authentication\nfunction login(username, password) {\n  // Login implementation\n}\n\n// @group authentication\nfunction logout() {\n  // Logout implementation\n}",
